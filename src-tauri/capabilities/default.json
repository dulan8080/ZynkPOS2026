{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for LassanaPata POS",
  "windows": ["main", "customer-display"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    {
      "identifier": "http:default",
      "allow": [
        "https://*/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ]
    }
  ]
}
